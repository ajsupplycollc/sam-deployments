# SAM Stack Credentials — fill in during live setup with client.
# Copy to $HOME/.sam/credentials.env then run install_mcps.sh
# DO NOT COMMIT this file. Add to .gitignore in any client repo.

CLIENT_SLUG=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Telegram ---
# Either client's own BotFather bot OR SAM-provisioned bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Shopify Admin ---
# Format: yourstore.myshopify.com  (no https://, no trailing slash)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=

# --- Postiz ---
# From postiz.com → Settings → API Keys
POSTIZ_API_KEY=

# --- Google Workspace ---
# Auth happens via Claude Code /mcp + browser. No keys here.
GOOGLE_PRIMARY_EMAIL=

# --- Klaviyo (only if client already runs Klaviyo and asks SAM to wire it) ---
KLAVIYO_PRIVATE_KEY=
